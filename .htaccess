Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to source files and config
    RewriteRule ^src/       - [F,L]
    RewriteRule ^config\.php$ - [F,L]
    RewriteRule ^composer\.json$ - [F,L]
    RewriteRule ^composer\.lock$ - [F,L]

    # Pass Authorization header through (cPanel/Apache strips it by default)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# Deny access to hidden files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
